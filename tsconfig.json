{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022",
		],
		"types": [
			"node",
			"mocha",
		],
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "./dist",
		"strict": true,   /* enable all strict type-checking options */

		/* Additional Checks */
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true,
	}
}
